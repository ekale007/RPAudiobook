{
  "name": "hoerbuch-ki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-no-bom.mjs",
    "dev": "next dev -H 0.0.0.0",
    "prebuild": "node scripts/ensure-no-bom.mjs",
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:sync": "node scripts/sync-seed.mjs",
    "tts:server": "python scripts/local-tts-server.py",
    "tts:kokoro": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-kokoro.ps1 --preload",
    "tts:kokoro:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-kokoro.ps1 --device cpu --preload",
    "tts:kokoro:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-kokoro.ps1",
    "tts:kokoro:install:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-kokoro.ps1 -CpuOnly",
    "tts:qwen": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-qwen.ps1 --preload",
    "tts:qwen:large": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-qwen.ps1 --preload --model Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice",
    "tts:qwen:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-qwen.ps1 --device cpu --preload",
    "tts:qwen:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-qwen.ps1",
    "runpod:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/runpod-build-push.ps1",
    "runpod:qwen:probe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/runpod-qwen-probe.ps1",
    "tts:qwen:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-qwen-local.ps1",
    "tts:qwen:session": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-qwen-session.ps1",
    "tts:omnivoice:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-omnivoice.ps1",
    "tts:omnivoice:install:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-omnivoice.ps1 -CpuOnly",
    "tts:omnivoice:refs": "python scripts/omnivoice-build-refs.py",
    "tts:omnivoice:probe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-omnivoice-probe.ps1",
    "tts:omnivoice:probe:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-omnivoice-probe.ps1 -NumStep 16",
    "covers:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-covers.ps1",
    "covers:install:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-covers.ps1 -CpuOnly",
    "covers:list-missing": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-covers.ps1 --list-missing",
    "covers:missing": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-covers.ps1 --missing",
    "covers:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-covers.ps1",
    "image-studio": "cd image-studio && npm run dev",
    "agentmemory:seed": "node scripts/seed-agentmemory.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "jszip": "^3.10.1",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.2.1"
  },
  "eslintConfig": {
    "extends": "next/core-web-vitals"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
