# Public Supabase keys only (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional production URL (magic links). On mobile LAN, set App URL on /login instead.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OpenRouter key stays in browser localStorage — never set here

# Kokoro TTS server only (npm run tts:kokoro) — read by Python, not sent to the browser
# Create at https://huggingface.co/settings/tokens (read access is enough)
# HF_TOKEN=hf_your_token_here
