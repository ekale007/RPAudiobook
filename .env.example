# Public Supabase keys only (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional production URL (magic links). On mobile LAN, set App URL on /login instead.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Beta: server-side keys (see docs/BETA-ELEVENLABS.md) ---
# ELEVENLABS_API_KEY=xi_...
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_NARRATOR_MODEL=
# RATE_LIMIT_LLM_PER_HOUR=80
# RATE_LIMIT_TTS_PER_HOUR=200
# BETA_LLM_BUDGET_CENTS=10000
# BETA_LLM_PROMPT_CENTS_PER_1K=0.3
# BETA_LLM_COMPLETION_CENTS_PER_1K=1.5
#
# Optional (auto-detected via GET /api/health if keys above are set):
# NEXT_PUBLIC_SERVER_TTS=1
# NEXT_PUBLIC_SERVER_LLM=1

# Kokoro TTS server only (npm run tts:kokoro) — read by Python, not sent to the browser
# Create at https://huggingface.co/settings/tokens (read access is enough)
# HF_TOKEN=hf_your_token_here
